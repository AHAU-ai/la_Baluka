{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "types": [
      "node"
    ],
    "noEmit": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "lib/**/*.ts",
    "scripts/**/*.ts",
    "popol-wuj-the-descent.ts",
    "popol-wuj-wuqub-kakix.ts",
    "popol-wuj-making-of-humans.ts",
    "katok-pa-tzij.ts"
  ]
}
